{
  "lastChangelogVersion": "0.78.0",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "medium",
  "theme": "catppuccin-macchiato",
  "showHardwareCursor": false,
  "packages": [
    "npm:@sherif-fanous/pi-catppuccin",
    "npm:pi-mermaid",
    "npm:visual-explainer",
    "npm:pi-web-access",
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-boomerang",
    "npm:pi-interactive-shell"
  ],
  "terminal": {
    "showTerminalProgress": false
  },
  "subagents": {
    "agentOverrides": {
      "oracle": {
        "thinking": "xhigh"
      },
      "planner": {
        "thinking": "xhigh"
      },
      "reviewer": {
        "thinking": "xhigh"
      },
      "worker": {
        "thinking": "xhigh"
      }
    }
  },
  "quietStartup": true
}